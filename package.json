    "@turf/line-intersect": "^7.3.5",
    "jshint": "^2.13.6",
    "plotly.js-cartesian-dist": "^3.6.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.2.5",
    "regression": "^2.0.1",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "electron": "^42.0.0",
